---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard/PostCard.astro";
import { getCollection } from "astro:content";
import "./blog-list.css";

const allPosts = await getCollection("blog");

const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// collect all unique tags across posts
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
---

<BaseLayout
  title="Blog"
  description="Articles on Astro, web performance, and frontend development."
>
  <section class="blog-header">
    <h1 class="page-title">Blog</h1>
    <p class="page-subtitle">
      {posts.length} articles on Astro, performance and the web.
    </p>

    <ul class="tag-filter">
      {allTags.map((tag) => <li class="tag-chip">{tag}</li>)}
    </ul>
  </section>

  <section class="posts-grid">
    {
      posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          publishDate={post.data.publishDate}
          author={post.data.author}
          tags={post.data.tags}
          slug={post.id}
          featured={post.data.featured}
        />
      ))
    }
  </section>
</BaseLayout>
